<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BrainEx.ViewModels"
             xmlns:m="clr-namespace:BrainEx.Models"
             x:Class="BrainEx.MainPage"
             Title="大脑多开器"
             BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#1C1C1E}">

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="14,10">

        <!-- ══ 顶栏 ══ -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,10" ColumnSpacing="8">

            <!-- 标题区 -->
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="🧠 大脑多开器"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}" />
                <Label Text="{Binding StatusText}"
                       FontSize="11"
                       TextColor="{AppThemeBinding Light=#8E8E93, Dark=#636366}"
                       Margin="2,1,0,0" />
            </VerticalStackLayout>

            <!-- 弹簧 -->
            <BoxView Grid.Column="1" Color="Transparent" />

            <!-- 📌 置顶按钮 -->
            <Button Grid.Column="2"
                    Text="{Binding PinButtonText}"
                    Command="{Binding TogglePinCommand}"
                    FontSize="18"
                    WidthRequest="44" HeightRequest="36"
                    CornerRadius="10"
                    BackgroundColor="{AppThemeBinding Light=#E5E5EA, Dark=#3A3A3C}"
                    TextColor="{Binding PinButtonColor}"
                    Padding="0" />

            <!-- ▶/⏹ 监听按钮 -->
            <Button Grid.Column="3"
                    Text="{Binding ListenButtonText}"
                    Command="{Binding ToggleListenCommand}"
                    BackgroundColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="12,6"
                    FontSize="13" />
        </Grid>

        <!-- ══ 统计栏 ══ -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto,Auto"
              Margin="0,0,0,10" ColumnSpacing="6">

            <Frame Grid.Column="0"
                   BackgroundColor="#E8F8EC"
                   CornerRadius="10" Padding="10,3" HasShadow="False">
                <Label  TextColor="White" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding PendingCount}" />
                            <Span Text=" 待处理" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Frame>

            <Frame Grid.Column="1"
                   BackgroundColor="#FFF3E0"
                   CornerRadius="10" Padding="10,3" HasShadow="False"
                   IsVisible="{Binding InProgressCount, Converter={StaticResource IntToBoolConverter}}">
                <Label TextColor="White" FontSize="12" FontAttributes="Bold"  HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding InProgressCount}" />
                            <Span Text=" 进行中" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Frame>

            <BoxView Grid.Column="2" Color="Transparent" />

            <!-- 显示/隐藏已完成 -->
            <Button Grid.Column="3"
                    Text="{Binding ShowDoneText}"
                    Command="{Binding ToggleShowDoneCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#8E8E93, Dark=#636366}"
                    FontSize="12"
                    Padding="6,3" />

            <Button Grid.Column="4"
                    Text="清除"
                    Command="{Binding ClearDoneCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#FF3B30, Dark=#FF453A}"
                    FontSize="12"
                    Padding="6,3" />
        </Grid>

        <!-- ══ 队列列表 ══ -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding VisibleQueue}">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Label Text="🫙" FontSize="40" HorizontalOptions="Center" />
                    <Label Text="队列为空"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#636366, Dark=#8E8E93}"
                           HorizontalOptions="Center" />
                    <Label Text="开始监听后，AI 的通知会自动出现在这里"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#AEAEB2, Dark=#636366}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:TaskItem">
                    <!-- 已完成：折叠成一行（灰色） -->
                    <Grid>

                        <!-- Done 状态：紧凑行 -->
                        <Frame IsVisible="{Binding IsDone}"
                               Margin="0,2" Padding="12,8"
                               CornerRadius="10" HasShadow="False"
                               BackgroundColor="{AppThemeBinding Light=#E5E5EA, Dark=#2C2C2E}"
                               Opacity="0.6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontSize="13"
                                       TextDecorations="Strikethrough"
                                       TextColor="{AppThemeBinding Light=#AEAEB2, Dark=#636366}"
                                       LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1"
                                       Text="✓"
                                       FontSize="13"
                                       TextColor="#34C759" />
                            </Grid>
                        </Frame>

                        <!-- Pending / InProgress 状态：完整卡片 -->
                        <SwipeView IsVisible="{Binding IsNotDone}">
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="完成 ✓"
                                               BackgroundColor="#34C759"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkDoneCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame Margin="0,4" Padding="14,12"
                                   CornerRadius="14" HasShadow="False"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2E}">

                                <!-- 进行中：左侧高亮条 -->
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding IsInProgress}"
                                                 Value="True">
                                        <Setter Property="BorderColor" Value="#FF9500" />
                                    </DataTrigger>
                                </Frame.Triggers>

                                <Grid ColumnDefinitions="44,*,Auto" RowDefinitions="Auto,Auto,Auto">

                                    <!-- App 头像 -->
                                    <Frame Grid.Column="0" Grid.RowSpan="3"
                                           WidthRequest="36" HeightRequest="36"
                                           CornerRadius="18" Padding="0"
                                           HasShadow="False"
                                           VerticalOptions="Center">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame"
                                                         Binding="{Binding IsInProgress}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor" Value="#FF9500" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Frame"
                                                         Binding="{Binding IsInProgress}"
                                                         Value="False">
                                                <Setter Property="BackgroundColor" Value="#007AFF" />
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Label Text="{Binding AppInitial}"
                                               TextColor="White"
                                               FontAttributes="Bold"
                                               FontSize="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Frame>

                                    <!-- 标题 -->
                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=#F5F5F7}"
                                           LineBreakMode="TailTruncation" />

                                    <!-- 正文 -->
                                    <Label Grid.Column="1" Grid.Row="1"
                                           Text="{Binding Body}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#636366, Dark=#8E8E93}"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2"
                                           Margin="0,2,0,0" />

                                    <!-- 来源 + 工作区 + 时间 -->
                                    <Label Grid.Column="1" Grid.Row="2"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light=#AEAEB2, Dark=#636366}"
                                           Margin="0,4,0,0">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding SourceApp}" />
                                                <Span Text="  " />
                                                <Span Text="{Binding WorkspaceLabel}"
                                                      TextColor="#007AFF"
                                                      FontAttributes="Bold" />
                                                <Span Text="  " />
                                                <Span Text="{Binding TimeLabel}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <!-- 右侧操作按钮区 -->
                                    <VerticalStackLayout Grid.Column="2" Grid.RowSpan="3"
                                                         VerticalOptions="Center"
                                                         Spacing="6" MinimumWidthRequest="70">

                                        <!-- Pending：开始按钮 -->
                                        <Button Text="▶ 开始"
                                                FontSize="12"
                                                Padding="10,5"
                                                CornerRadius="8"
                                                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#3A3A3C}"
                                                TextColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"
                                                IsVisible="{Binding IsPending}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StartTaskCommand}"
                                                CommandParameter="{Binding .}" />

                                        <!-- InProgress：跳转 IDE + 完成 两个按钮 -->
                                        <Button Text="🔀 IDE"
                                                FontSize="12"
                                                Padding="10,5"
                                                CornerRadius="8"
                                                BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3A2E00}"
                                                TextColor="#FF9500"
                                                IsVisible="{Binding IsInProgress}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FocusIdeCommand}"
                                                CommandParameter="{Binding .}" />

                                        <Button Text="✓ 完成"
                                                FontSize="12"
                                                Padding="10,5"
                                                CornerRadius="8"
                                                BackgroundColor="{AppThemeBinding Light=#E8F8EC, Dark=#0D2E15}"
                                                TextColor="#34C759"
                                                IsVisible="{Binding IsInProgress}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkDoneCommand}"
                                                CommandParameter="{Binding .}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </SwipeView>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ══ 底部手动添加 ══ -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto"
              Margin="0,8,0,4" ColumnSpacing="8">
            <Frame Grid.Column="0" Padding="4,0" CornerRadius="10" HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2E}">
                <Entry x:Name="ManualEntry"
                       Placeholder="手动添加任务…"
                       ReturnType="Done"
                       Completed="OnManualEntryCompleted"
                       FontSize="14" />
            </Frame>
            <Button Grid.Column="1"
                    Text="＋"
                    FontSize="18"
                    WidthRequest="46" HeightRequest="46"
                    CornerRadius="23"
                    BackgroundColor="{AppThemeBinding Light=#007AFF, Dark=#0A84FF}"
                    TextColor="White"
                    Clicked="OnAddButtonClicked" />
        </Grid>

    </Grid>
</ContentPage>
